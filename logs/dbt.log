  create or replace view `dbt-challenge-manuable`.`raw`.`stg_products`
  OPTIONS()
  as 

SELECT DISTINCT
  product_id,
  TRIM(name) AS product_name,
  SAFE_CAST(price AS NUMERIC) AS price
FROM `dbt-challenge-manuable`.`raw`.`products`
WHERE product_id IS NOT NULL
ORDER BY product_id;


