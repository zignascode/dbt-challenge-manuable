[0m17:16:15.919370 [debug] [Thread-2 (]: On model.dbt_challenge_manuable.stg_order_items: /* {"app": "dbt", "dbt_version": "1.11.9", "profile_name": "dbt_challenge_manuable", "target_name": "dev", "node_id": "model.dbt_challenge_manuable.stg_order_items"} */


  create or replace view `dbt-challenge-manuable`.`raw`.`stg_order_items`
  OPTIONS()
  as 

SELECT
  order_id,
  product_id,
  quantity

FROM (
  SELECT
    order_id,
    product_id,
    SAFE_CAST(quantity AS INT64) AS quantity,
    CASE -- Si el producto no existe en stg_products, lo marcamos como "NOT EXIST"
      WHEN product_id NOT IN (SELECT product_id FROM `dbt-challenge-manuable`.`raw`.`products`)
        THEN 'NOT EXIST'
        ELSE product_id
    END AS existance_condition,
    CASE -- Si la cantidad es negativa, lo marcamos como "INVALID"
      WHEN SAFE_CAST(quantity AS INT64) < 0
        THEN 'INVALID'
    END AS quantity_condition
  FROM `dbt-challenge-manuable`.`raw`.`order_items`
)

WHERE existance_condition <> 'NOT EXIST'
AND quantity_condition IS NULL
AND order_id IS NOT NULL
ORDER BY order_id DESC;


