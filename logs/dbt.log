    create or replace table `dbt-challenge-manuable`.`raw`.`mart_customer_ltv`
      
    
    

    
    OPTIONS()
    as (
      

SELECT
    customer_id,
    customer_name,
    email,
    first_order_date,
    last_order_date,
    total_orders,
    total_revenue,
    -- Se usa aquí la macros customer_segment para segmentar a los clientes
    
    CASE
      WHEN total_revenue > 5000 THEN 'VIP'
      WHEN total_revenue > 500 THEN 'Regular'
      WHEN total_orders < 2 THEN 'NUEVO'
      ELSE 'Regular'
    END
 AS customer_segment
FROM `dbt-challenge-manuable`.`raw`.`int_customers`
ORDER BY customer_id DESC
    );
  
