  create or replace view `dbt-challenge-manuable`.`raw`.`int_orders`
  OPTIONS()
  as 

WITH orders_products AS (
    SELECT
        oi.order_id,
        oi.product_id,
        p.product_name,
        p.price,
        oi.quantity,
        oi.quantity * p.price AS item_revenue
    FROM `dbt-challenge-manuable`.`raw`.`stg_order_items` oi
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_products` p ON (oi.product_id = p.product_id)
)

SELECT
    o.order_id,
    o.order_status,
    o.order_date,
    o.customer_id,
    op.product_id,
    op.product_name,
    op.price,
    op.quantity,
    op.item_revenue

FROM `dbt-challenge-manuable`.`raw`.`stg_orders` o
LEFT JOIN orders_products op ON (o.order_id = op.order_id)

ORDER BY order_id DESC;


[0m23:03:37.894884 [debug] [Thread-1 (]: On model.dbt_challenge_manuable.int_customers: /* {"app": "dbt", "dbt_version": "1.11.9", "profile_name": "dbt_challenge_manuable", "target_name": "dev", "node_id": "model.dbt_challenge_manuable.int_customers"} */


  create or replace view `dbt-challenge-manuable`.`raw`.`int_customers`
  OPTIONS()
  as 

WITH customer_orders AS (
    SELECT
        o.customer_id,
        o.order_id,
        o.order_date,
        o.order_status,
        c.customer_name,
        c.email,
        oi.quantity * p.price AS order_revenue
    FROM `dbt-challenge-manuable`.`raw`.`stg_orders` o
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_order_items` oi ON (o.order_id = oi.order_id)
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_products` p ON (oi.product_id = p.product_id)
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_customers` c ON (o.customer_id = c.customer_id)
)

SELECT
    customer_id,
    customer_name,
    email,
    COUNT(DISTINCT order_id) AS total_orders,
    SUM(order_revenue) AS total_revenue,
    MIN(order_date) AS first_order_date,
    MAX(order_date) AS last_order_date
FROM customer_orders
GROUP BY customer_id, customer_name, email
ORDER BY customer_id DESC;


