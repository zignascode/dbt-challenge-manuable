  create or replace view `dbt-challenge-manuable`.`raw`.`int_customers`
  OPTIONS()
  as 

WITH orders_products AS (
    SELECT
        oi.order_id,
        SUM(oi.quantity * p.price) AS total_revenue
    FROM `dbt-challenge-manuable`.`raw`.`stg_order_items` oi
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_products` p ON (oi.product_id = p.product_id)
    GROUP BY oi.order_id
)

SELECT DISTINCT
  o.customer_id,
  c.customer_name,
  c.email,
  COUNT(DISTINCT o.order_id) AS total_orders,
  MIN(o.order_date) AS first_order_date,
  MAX(o.order_date) AS last_order_date,
  SUM(op.total_revenue) AS total_revenue

FROM `dbt-challenge-manuable`.`raw`.`stg_orders` o
LEFT JOIN orders_products op ON (o.order_id = op.order_id)
LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_customers` c ON (o.customer_id = c.customer_id)
GROUP BY o.customer_id,c.customer_name,c.email
ORDER BY o.customer_id DESC;


[0m05:54:11.242676 [debug] [Thread-1 (]: On model.dbt_challenge_manuable.int_orders: /* {"app": "dbt", "dbt_version": "1.11.9", "profile_name": "dbt_challenge_manuable", "target_name": "dev", "node_id": "model.dbt_challenge_manuable.int_orders"} */


  create or replace view `dbt-challenge-manuable`.`raw`.`int_orders`
  OPTIONS()
  as 

WITH orders_products AS (
    SELECT
        oi.order_id,
        oi.product_id,
        p.product_name,
        p.price,
        oi.quantity,
        oi.quantity * p.price AS item_revenue
    FROM `dbt-challenge-manuable`.`raw`.`stg_order_items` oi
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_products` p ON (oi.product_id = p.product_id)
)

SELECT
    o.order_id,
    o.order_status,
    o.order_date,
    o.customer_id,
    op.product_id,
    op.product_name,
    op.price,
    op.quantity,
    op.item_revenue

FROM `dbt-challenge-manuable`.`raw`.`stg_orders` o
LEFT JOIN orders_products op ON (o.order_id = op.order_id)

ORDER BY order_id DESC;


