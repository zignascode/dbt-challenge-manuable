  create or replace view `dbt-challenge-manuable`.`raw`.`int_orders`
  OPTIONS()
  as 

WITH orders_products AS (
    SELECT
        oi.order_id,
        oi.product_id,
        p.product_name,
        p.price,
        oi.quantity,
        oi.quantity * p.price AS item_revenue
    FROM `dbt-challenge-manuable`.`raw`.`stg_order_items` oi
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_products` p ON (oi.product_id = p.product_id)
)

SELECT
    op.order_id,
    o.order_status,
    o.order_date,
    o.customer_id,
    op.product_id,
    op.product_name,
    op.price,
    op.quantity,
    op.item_revenue

FROM orders_products op
LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_orders` o ON (op.order_id = o.order_id)

ORDER BY order_id DESC;


