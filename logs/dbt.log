[0m18:53:04.992181 [debug] [Thread-2 (]: On model.dbt_challenge_manuable.int_orders: /* {"app": "dbt", "dbt_version": "1.11.9", "profile_name": "dbt_challenge_manuable", "target_name": "dev", "node_id": "model.dbt_challenge_manuable.int_orders"} */


  create or replace view `dbt-challenge-manuable`.`raw`.`int_orders`
  OPTIONS()
  as 

WITH orders_revenue AS (
    SELECT
        oi.order_id,
        oi.product_id,
        p.product_name,
        oi.quantity,
        p.price,
        oi.quantity * p.price AS item_revenue --monto por producto
    FROM `dbt-challenge-manuable`.`raw`.`stg_order_items` oi
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_products` p ON (oi.product_id = p.product_id)
)

SELECT
    o.order_id,
    o.customer_id,
    o.order_date,
    o.order_status,
    SUM(oi.item_revenue) AS total_revenue, --total de la orden
    COUNT(DISTINCT oi.product_id) AS total_products -- conteo de productos distintos
FROM `dbt-challenge-manuable`.`raw`.`stg_orders` o
LEFT JOIN orders_revenue oi ON (o.order_id = oi.order_id)
GROUP BY o.order_id, o.customer_id, o.order_date, o.order_status
ORDER BY order_id DESC;


[0m18:53:05.002002 [debug] [Thread-1 (]: On model.dbt_challenge_manuable.int_customers: /* {"app": "dbt", "dbt_version": "1.11.9", "profile_name": "dbt_challenge_manuable", "target_name": "dev", "node_id": "model.dbt_challenge_manuable.int_customers"} */


  create or replace view `dbt-challenge-manuable`.`raw`.`int_customers`
  OPTIONS()
  as 

WITH customer_orders AS (
    SELECT
        o.customer_id,
        o.order_id,
        o.order_date,
        o.order_status,
        SUM(oi.quantity * p.price) AS order_revenue
    FROM `dbt-challenge-manuable`.`raw`.`stg_orders` o
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_order_items` oi ON (o.order_id = oi.order_id)
    LEFT JOIN `dbt-challenge-manuable`.`raw`.`stg_products` p ON (oi.product_id = p.product_id)
    GROUP BY o.customer_id, o.order_id, o.order_date, o.order_status
)

SELECT
    c.customer_id,
    c.customer_name,
    c.email,
    COUNT(DISTINCT co.order_id) AS total_orders,
    SUM(co.order_revenue) AS total_revenue,
    MIN(co.order_date) AS first_order_date,
    MAX(co.order_date) AS last_order_date
FROM `dbt-challenge-manuable`.`raw`.`stg_customers` c
LEFT JOIN customer_orders co ON (c.customer_id = co.customer_id)
GROUP BY c.customer_id, c.customer_name, c.email
ORDER BY customer_id DESC;


