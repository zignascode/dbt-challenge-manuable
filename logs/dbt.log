  create or replace view `dbt-challenge-manuable`.`raw`.`stg_customers`
  OPTIONS()
  as 

SELECT
  customer_id,
  -- Se usa aquí la macro normalize_text para limpiar y estandarizar los campos de texto
  
    LOWER(TRIM(name))
 AS customer_name,
  
    LOWER(TRIM(email))
 AS email
FROM `dbt-challenge-manuable`.`raw`.`customers`
WHERE customer_id IS NOT NULL
AND name IS NOT NULL
